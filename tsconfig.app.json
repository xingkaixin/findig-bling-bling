{
  "extends": "./tsconfig.node.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "jsx": "react-jsx",
    "types": ["chrome", "vite/client"],
    "baseUrl": "./src",
    "paths": {
      "@popup/*": ["popup/*"],
      "@content/*": ["content/*"],
      "@shared/*": ["shared/*"],
      "@injected/*": ["injected/*"]
    }
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}
